{
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "SLASH_COMMAND_TOOL_CHAR_BUDGET": "32000"
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git fetch*)",
      "Bash(git branch*)",
      "Bash(git -C * status*)",
      "Bash(git -C * diff*)",
      "Bash(git -C * log*)",
      "Bash(git -C * show*)",
      "Bash(git -C * fetch*)",
      "Bash(git -C * branch*)",
      "Bash(go *)",
      "Bash(make*)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(rm -rf .claude*)",
      "WebSearch(*)",
      "Fetch(https://*)",
      "Read(~/.claude/skills/**/*.md)"
