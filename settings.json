    "deny": [],
    "ask": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git reset*)",
      "Bash(git restore*)",
      "Bash(git cherry-pick*)",
      "Bash(git tag*)",
      "Bash(git stash*)",
      "Read(**/.env)",
      "Read(**/*.key)"
