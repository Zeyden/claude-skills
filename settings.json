{
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-sonnet-4-6"
  },
  "permissions": {
    "allow": [
      "Bash(git:status)",
      "Bash(git:diff*)",
      "Bash(git:log*)",
      "Bash(git:show*)",
      "Bash(git:fetch*)",
      "Bash(git:branch*)",
      "Bash(go:*)",
      "Bash(make:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(rm -rf .claude*)"
    ],
    "deny": [
      "Bash(git:push*)"
    ],
    "ask": [
      "Bash(git:commit*)",
      "Bash(git:merge*)",
      "Bash(git:rebase*)",
      "Bash(git:reset*)",
      "Bash(git:restore*)",
      "Bash(git:cherry-pick*)",
      "Bash(git:tag*)",
      "Bash(git:stash*)",
      "Read(**/.env)",
      "Read(**/*.key)"
    ]
  },
  "model": "claude-opus-4-6",
  "language": "English UK",
  "effortLevel": "high",
  "maxTokens": 128000
}
